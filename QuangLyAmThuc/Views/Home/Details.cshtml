@model QuanLyAmThuc.Models.MonAn

@if (Model != null)
{
    <div class="container my-5">
        <div class="row g-5">
            <div class="col-md-6">
                <img src="@Model.HinhAnh" class="img-fluid rounded-3 shadow" style="width: 100%; height: 400px; object-fit: cover;">
            </div>
            <div class="col-md-6">
                <h1 class="fw-bold text-dark mb-2">@Model.TenMon</h1>
                <p class="text-danger fw-bold fs-5">📍 Thuộc vùng: @Model.DacSan (@Model.VungMien)</p>
                <hr>
                <h4 class="fw-bold text-secondary"><i class="bi bi-info-circle-fill"></i> 1. Giới thiệu món ăn</h4>
                <p class="text-muted" style="text-align: justify;">@Model.MoTa</p>

                <h4 class="fw-bold text-success mt-4"><i class="bi bi-cart-check-fill"></i> 2. Nguyên liệu chuẩn bị</h4>
                <div class="p-3 bg-success bg-opacity-10 border border-success border-opacity-25 rounded-3">
                    <p class="mb-0 text-dark">@Model.NguyenLieu</p>
                </div>

                <a href="@Url.Action("Index")" class="btn btn-outline-secondary mt-5"><i class="bi bi-arrow-left"></i> Quay lại danh sách</a>
            </div>
        </div>
    </div>
}